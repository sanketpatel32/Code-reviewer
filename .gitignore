!.env.example

# Local Mira data
# - data/app.db is the SQLite-backed app DB
# - data/indexes/ contains per-repo code indexes
# Both are runtime state, never source.
data/

# Demo / scratch output that ends up in the repo root from local runs
report.txt
*.tmp

# Benchmark reports — produced by local eval runs, not part of the release.
BENCHMARK_REPORT*.md
tests/benchmarks/runs/

# Local eval-regression fixtures — repo-specific PR URLs and history.
tests/eval_regressions/

# Frontend
ui/mira/node_modules/
ui/mira/dist/
ui/mira/.vite/

# Claude Code workspace artifacts
.claude/
