# Mira configuration file
# Copy this to .mira.yaml in your repository root

llm:
  # Provider: "openai" (default, any OpenAI-compatible endpoint) or "bedrock" (AWS)
  # provider: "openai"

  # Model identifier (any LiteLLM-supported model)
  model: "openai/gpt-4o"
  # Fallback model if primary fails
  fallback_model: "openai/gpt-4o-mini"
  temperature: 0.2
  max_tokens: 4096

  # ── AWS Bedrock configuration (uncomment to use) ──
  # provider: "bedrock"
  # model: "us.anthropic.claude-sonnet-4-6-v1:0"
  # fallback_model: "us.anthropic.claude-haiku-4-5-v1:0"
  # region: "us-east-1"
  # aws_profile: "my-profile"  # optional, uses default AWS credential chain if omitted

filter:
  # Minimum confidence threshold (0.0 - 1.0)
  confidence_threshold: 0.7
  # Maximum number of comments to post
  max_comments: 5
  # Minimum severity level: blocker, warning, suggestion, nitpick
  min_severity: "nitpick"
  # Glob patterns for files to exclude
  exclude_patterns:
    - "*.lock"
    - "*.lockb"
    - "package-lock.json"
    - "yarn.lock"
    - "pnpm-lock.yaml"
    - "*.min.js"
    - "*.min.css"
    - "*.map"
    - "*.svg"
    - "*.png"
    - "*.jpg"
    - "*.gif"
  # Skip deleted files
  exclude_deleted: true
  # Maximum number of files to review
  max_files: 50

review:
  # Lines of context around hunks
  context_lines: 3
  # Maximum diff size in characters
  max_diff_size: 50000
  # Only flag critical problems/bugs (false = also suggest improvements)
  focus_only_on_problems: false
  # Include a summary comment
  include_summary: true
  # Generate a PR walkthrough comment (top-level summary)
  walkthrough: true
  # Include a Mermaid sequence diagram in the walkthrough
  walkthrough_sequence_diagram: true
